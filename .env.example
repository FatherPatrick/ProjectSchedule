# --- App ---
# Public site URL (used for cancel links, email/SMS callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BUSINESS_NAME="Virgo Nailz"
NEXT_PUBLIC_BUSINESS_TIMEZONE="America/Los_Angeles"

# --- Database (Postgres) ---
# Use Neon (Vercel Postgres successor) or any Postgres. Use a pooled URL for serverless.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET=""
# For magic-link sign-in (optional client accounts + admin login)
EMAIL_FROM="Virgo Nailz <bookings@yourdomain.com>"

# --- Resend (email) ---
RESEND_API_KEY=""

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+15555555555"

# --- Cron (Vercel Cron) ---
# Shared secret to authorize the /api/cron/* endpoints.
CRON_SECRET=""

# --- Admin bootstrap ---
# Email addresses (comma-separated) automatically promoted to ADMIN on first sign-in.
ADMIN_EMAILS=""

# --- App ---
# Public site URL (used for cancel links, email/SMS callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BUSINESS_NAME="Virgo Nailz"
NEXT_PUBLIC_BUSINESS_TIMEZONE="America/Los_Angeles"

# --- Database (Postgres) ---
# Use Neon. Use the POOLED URL (with `-pooler` in the host) for the app.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require"
# Use the UNPOOLED URL (same as above, minus `-pooler`) for Prisma migrations.
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/db?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret
AUTH_SECRET=""
# For magic-link sign-in and booking emails.
# Sandbox (no domain): use "Your Studio <onboarding@resend.dev>" — emails will
# only deliver to the address that owns the Resend account.
# Production: use a verified domain in Resend, e.g. "Your Studio <bookings@yourdomain.com>"
EMAIL_FROM="Virgo Nailz <onboarding@resend.dev>"

# --- Resend (email) ---
RESEND_API_KEY=""

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+15555555555"

# --- Cron (Vercel Cron) ---
# Shared secret to authorize the /api/cron/* endpoints.
CRON_SECRET=""

# --- Admin bootstrap ---
# Email addresses (comma-separated) automatically promoted to ADMIN on first sign-in.
ADMIN_EMAILS=""
